# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — it stays on your machine only.
# Never paste real keys into this file or into git.

# ─── Database (Postgres) ────────────────────────────────────────────
# Get from Neon, Supabase, or whatever Postgres host you pick.
DATABASE_URL="postgresql://user:password@host:5432/sandbox"

# ─── Clerk (auth / login) ───────────────────────────────────────────
# Dashboard: https://dashboard.clerk.com
# The "publishable" key is safe for the browser; the "secret" key is server-only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# ─── Stripe (payments) ──────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
# Use TEST keys for dev, LIVE keys only in production.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── App config ─────────────────────────────────────────────────────
# Public URL the app runs at. Used for Stripe redirects and Clerk callbacks.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
