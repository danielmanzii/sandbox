# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — it stays on your machine only.
# Never paste real keys into this file or into git.
#
# These vars are for the long-term Next.js port in `web/`. The live `v1/`
# app uses Supabase directly with the anon key inlined in
# `v1/components/supabase-client.jsx` (intentional — public anon role
# guarded by RLS), so it has no env requirements to run locally.

# ─── Supabase (auth + data for the live v1 app) ─────────────────────
# Project: rklxjcchgtwgxbeatsoc.supabase.co
# Dashboard: https://supabase.com/dashboard
# v1 inlines URL + anon key in supabase-client.jsx (safe — RLS protects).
# When `web/` ports over, it should read from these env vars instead.
NEXT_PUBLIC_SUPABASE_URL="https://rklxjcchgtwgxbeatsoc.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="paste-the-anon-key-from-supabase-client.jsx"
# SERVICE ROLE KEY — server-only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY="paste-from-supabase-dashboard-keep-secret"

# ─── Stripe (payments) ──────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
# Use TEST keys for dev, LIVE keys only in production.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── App config ─────────────────────────────────────────────────────
# Public URL the app runs at. Used for Stripe redirects and auth callbacks.
# Production: https://www.sbx.golf — this should match Supabase's Site URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
